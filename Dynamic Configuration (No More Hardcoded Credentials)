import json

CONFIG_FILE = os.path.expanduser("~/.devauto_config.json")

def load_or_create_config():
    """Loads configuration rules or creates a default one if missing."""
    default_config = {
        "default_commit_message": "Automated update via DevAuto",
        "auto_format_before_push": True,
        "run_tests_before_push": True
    }
    
    if not os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "w") as f:
            json.dump(default_config, f, indent=4)
        return default_config
        
    with open(CONFIG_FILE, "r") as f:
        return json.load(f)
